// flash_m33.jlink
// Specify the target chip (Please adjust according to your actual i.MX93 model, e.g., MIMX9352_M33)
device MIMX9352_M33
// Use SWD interface
if SWD
// Set connection speed (kHz)
speed 4000
// Connect to the target board
connect
// Pause CPU
h
// Flash the compiled Hex or Bin file to the specified memory address 
loadfile ./Objects/M33_Firmware.hex
// Reset and execute
r
g
// Exit J-Link Commander
qc